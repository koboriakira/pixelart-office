// Pixel Art Office — Claude Code Hook 設定
//
// セットアップ: bash examples/install-hooks.sh
//
// ヘルパースクリプト (~/.local/bin/pixelart-office-hook.sh) を経由して
// イベントを送信する方式。エスケープ不要でメンテナンスしやすい。
//
// エージェントID: claude-{リポジトリ名}-main
// サーバー停止時: --max-time 1 で即タイムアウト、セッションに影響なし
{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/pixelart-office-hook.sh session_start"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/pixelart-office-hook.sh tool_use_start $CLAUDE_TOOL_NAME"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/pixelart-office-hook.sh tool_use_end"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/pixelart-office-hook.sh session_stop"
          }
        ]
      }
    ]
  }
}
